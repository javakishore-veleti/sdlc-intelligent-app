# Knowledge-Service configuration

# Vector DB (ChromaDB)
CHROMA_MODE=http            # http | ephemeral | persistent
CHROMA_HOST=localhost
CHROMA_PORT=8000
# CHROMA_PERSIST_DIR=./chroma-data

# Must match the ingestion DAG's embedding dimension
EMBEDDING_DIM=256

# Retrieval defaults
DEFAULT_FRAMEWORK=langchain          # langchain | langgraph
DEFAULT_STRATEGY=recursive_char_2000_200
DEFAULT_TOP_K=4

# Answer generation: extractive (default) | ollama | groq (future)
ANSWER_BACKEND=extractive
