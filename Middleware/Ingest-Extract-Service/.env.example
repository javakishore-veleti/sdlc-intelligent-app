# Ingest-Extract-Service configuration

# Database (ingest_log). Local default; Postgres in containers.
DATABASE_URL=sqlite:///./ingest.db
# DATABASE_URL=postgresql+psycopg2://sdlc:sdlc@postgres:5432/ingest

# Storage backend: local (default) | aws_s3 | azure_blob (future)
STORAGE_BACKEND=local
# Datalake root (default: ~/runtime_data/sdlc-intelligent-app)
# DATALAKE_BASE_PATH=/home/you/runtime_data/sdlc-intelligent-app

# Airflow trigger
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_DAG_ID=ingest_sprint_docs_to_vector_db
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_TRIGGER_ENABLED=true
